# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Serper API
SERPER_API_KEY=your_serper_api_key

# App
NEXT_PUBLIC_APP_URL=https://www.gotopseo.com

# Google OAuth (Optional - use your own Google OAuth app instead of Supabase's)
# Leave empty to use Supabase's built-in Google provider
# NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
